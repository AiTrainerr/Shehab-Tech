generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  middleName    String?
  lastName      String
  email         String    @unique
  password      String?
  role          String    @default("MEMBER") // ADMIN, MEMBER
  gender        String?
  country       String?
  age           Int?
  phone         String?
  whatsapp      String?
  
  // Verification
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  idCardUrl     String?
  selfieUrl     String?
  verificationStatus String @default("NOT_VERIFIED") // NOT_VERIFIED, PENDING, VERIFIED, REJECTED
  verificationReason String?
  
  // Profile specifics
  avatarUrl     String?
  fullAvatarUrl String?
  cvUrl         String?
  bio           String?
  ranking       String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, VERIFIED, EXPERT, PREMIUM
  completedCount Int      @default(0)
  rating        Float     @default(0.0)
  projectTypes  String[]  @default([])
  
  // Payment info
  paymentMethod      String?
  paymentId          String?
  paymentEmail       String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  skills        UserSkill[]
  languages     UserLanguage[]
  applications  Application[]
  notifications Notification[]
  messagesSent  Message[] @relation("SentMessages")
  messagesRecv  Message[] @relation("ReceivedMessages")
  portfolios    Portfolio[]
  comments      Comment[]
  voiceRecordings    VoiceRecording[]
  pushSubscriptions  PushSubscription[]
  assignedTasks      TranscriptionTask[] @relation("AssignedTranscriber")
  qcTasks            TranscriptionTask[] @relation("AssignedQC")
  teamTasks          TranscriptionTask[] @relation("TeamTasks")
  moderatorReviews   TranscriptionReview[]

  // Team features
  teamLeaderId       String?
  teamLeader         User?   @relation("TeamMembers", fields: [teamLeaderId], references: [id])
  teamMembers        User[]  @relation("TeamMembers")
  teamRole           String? // TRANSCRIBER, QC

  // Moderator fields
  isApproved         Boolean  @default(false)
  assignedProjectId  String?
  assignedProject    Project? @relation("ProjectModerators", fields: [assignedProjectId], references: [id], onDelete: SetNull)
  canReviewQC        Boolean  @default(false)
  canApproveApplications Boolean @default(false)
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  users     UserSkill[]
  projects  ProjectSkill[]
}

model UserLanguage {
  id          String   @id @default(cuid())
  userId      String
  language    String
  proficiency String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSkill {
  userId  String
  skillId String
  user    User  @relation(fields: [userId], references: [id])
  skill   Skill @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
}

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String
  instructions    String?
  privateData     String?        // Hidden info revealed only when application is APPROVED
  autoApprove     Boolean        @default(false)
  
  // Requirements
  reqCountry      String?
  reqPhoneType    String?
  reqAgeMin       Int?
  reqAgeMax       Int?
  reqExperience   String?
  
  price             Float?
  recordingDuration Float?  // Duration in hours or sentence count
  durationUnit      String  @default("HOUR") // HOUR, SENTENCE
  pricingModel      String  @default("FIXED_PROJECT") // PER_HOUR, PER_SENTENCE, FIXED_PROJECT
  status            String  @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // New fields for audio collection specs
  executionOption      String   @default("INTERNAL") // INTERNAL, EXTERNAL
  externalUrl          String?
  audioFormat          String   @default("WAV") // WAV, FLAC, MP3
  sampleRate           Int      @default(44100) // 8000, 16000, 22050, 44100, 48000
  bitDepth             Int      @default(16) // 16, 24, 32
  channels             String   @default("MONO") // MONO, STEREO
  minDuration          Int?     // in seconds
  maxDuration          Int?     // in seconds
  hasScript            Boolean  @default(true)
  scriptType           String   @default("STATIC") // STATIC, RANDOM, CATEGORY
  namingRule           String   @default("SEQUENCE") // TEXT, SEQUENCE
  requiredParticipants Int      @default(1)
  targetMales          Int      @default(0)
  targetFemales        Int      @default(0)

  // Transcription Platform fields
  isTranscriptionProject Boolean @default(false)
  workflowType           String  @default("MOD_ONLY") // MOD_ONLY, MOD_AND_QC
  outputFormat           String  @default("WORD") // WORD, EXCEL, JSON, SRT
  allowFreelancerDownload Boolean @default(false)

  skills          ProjectSkill[]
  applications    Application[]
  comments        Comment[]
  languages       ProjectLanguage[]
  images          ProjectImage[]
  sentences       ProjectSentence[]
  moderators      User[]           @relation("ProjectModerators")
  transcriptionTasks TranscriptionTask[]
}

model ProjectSentence {
  id          String          @id @default(cuid())
  projectId   String
  text        String
  order       Int
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordings  VoiceRecording[]
  createdAt   DateTime        @default(now())
}

model VoiceRecording {
  id           String          @id @default(cuid())
  sentenceId   String
  userId       String
  fileUrl      String          // Cloudinary URL
  publicId     String          // Cloudinary public_id for deletion
  expiresAt    DateTime        // uploadedAt + 24h
  movedToCloud Boolean         @default(false)

  // Quality Control & Audio Specs fields
  status          String          @default("PENDING") // PENDING, ACCEPTED, REJECTED, NEED_RE_RECORD
  rejectionReason String?
  fileSize        Int             @default(0)
  duration        Float           @default(0.0)
  audioFormat     String          @default("WAV")
  sampleRate      Int             @default(44100)
  bitDepth        Int             @default(16)
  channels        String          @default("MONO")
  reviewedBy      String?

  sentence     ProjectSentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id])
  createdAt    DateTime        @default(now())
  @@unique([sentenceId, userId])
}

model ProjectLanguage {
  id              String   @id @default(cuid())
  projectId       String
  language        String
  dialect         String?
  proficiency     String?
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectImage {
  id              String   @id @default(cuid())
  projectId       String
  url             String
  caption         String?
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectSkill {
  projectId String
  skillId   String
  project   Project @relation(fields: [projectId], references: [id])
  skill     Skill   @relation(fields: [skillId], references: [id])

  @@id([projectId, skillId])
}

model Application {
  id          String            @id @default(cuid())
  projectId   String
  userId      String
  status          String            @default("PENDING") // PENDING, ACCEPTED, WORKING, UNDER_REVIEW, APPROVED, PAID, REJECTED
  proofUrl        String?           // For task completion proof
  speakerCode     String?           // e.g., "G0001", assigned upon approval
  applicationType String            @default("FREELANCER") // FREELANCER, TEAM_LEADER
  projectRole     String            @default("TRANSCRIBER") // TRANSCRIBER, QC
  
  project     Project           @relation(fields: [projectId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([projectId, userId])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  fileUrl     String?
  imageUrl    String?
  
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Comment {
  id          String   @id @default(cuid())
  projectId   String
  authorId    String
  content     String
  parentId    String?
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  isRead      Boolean  @default(false)
  
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  isRead      Boolean  @default(false)
  link        String?
  
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model LearningResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String
  imageUrl    String?
  category    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  username    String?
  action      String
  details     String
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Transcription Platform Models
// ─────────────────────────────────────────────────────────────────────────────

model TranscriptionTask {
  id              String   @id @default(cuid())
  projectId       String
  audioFilePath   String
  duration        Float?   // in seconds
  speakerCount    Int      @default(1)
  status          String   @default("AVAILABLE") // AVAILABLE, ASSIGNED, SUBMITTED_TO_QC, UNDER_QC_REVIEW, APPROVED_BY_QC, APPROVED, REJECTED
  isFailed        Boolean  @default(false)
  
  assignedToId    String?
  assignedTo      User?    @relation("AssignedTranscriber", fields: [assignedToId], references: [id], onDelete: SetNull)

  qcAssignedToId  String?
  qcAssignedTo    User?    @relation("AssignedQC", fields: [qcAssignedToId], references: [id], onDelete: SetNull)

  teamId          String?
  teamLeader      User?    @relation("TeamTasks", fields: [teamId], references: [id], onDelete: SetNull)
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  segments        TranscriptionSegment[]
  reviews         TranscriptionReview[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TranscriptionSegment {
  id              String   @id @default(cuid())
  taskId          String
  startTime       Float
  endTime         Float
  speakerLabel    String   @default("Speaker 1")
  transcriptText  String   @default("")
  isValid         Boolean  @default(true)

  task            TranscriptionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TranscriptionReview {
  id              String   @id @default(cuid())
  taskId          String
  moderatorId     String
  status          String   // APPROVED, REJECTED
  notes           String?

  task            TranscriptionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  moderator       User              @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  reviewedAt      DateTime @default(now())
}
