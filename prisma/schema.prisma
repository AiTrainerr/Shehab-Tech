generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  middleName    String?
  lastName      String
  email         String    @unique
  password      String?
  role          String    @default("MEMBER") // ADMIN, MEMBER
  gender        String?
  country       String?
  age           Int?
  phone         String?
  whatsapp      String?
  
  // Verification
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  idCardUrl     String?
  selfieUrl     String?
  verificationStatus String @default("NOT_VERIFIED") // NOT_VERIFIED, PENDING, VERIFIED, REJECTED
  
  // Profile specifics
  avatarUrl     String?
  fullAvatarUrl String?
  cvUrl         String?
  bio           String?
  ranking       String   @default("BEGINNER") // BEGINNER, INTERMEDIATE, VERIFIED, EXPERT, PREMIUM
  completedCount Int      @default(0)
  rating        Float     @default(0.0)
  projectTypes  String[]  @default([])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  skills        UserSkill[]
  languages     UserLanguage[]
  applications  Application[]
  notifications Notification[]
  messagesSent  Message[] @relation("SentMessages")
  messagesRecv  Message[] @relation("ReceivedMessages")
  portfolios    Portfolio[]
  comments      Comment[]
  voiceRecordings VoiceRecording[]
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  users     UserSkill[]
  projects  ProjectSkill[]
}

model UserLanguage {
  id          String   @id @default(cuid())
  userId      String
  language    String
  proficiency String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSkill {
  userId  String
  skillId String
  user    User  @relation(fields: [userId], references: [id])
  skill   Skill @relation(fields: [skillId], references: [id])

  @@id([userId, skillId])
}

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String
  instructions    String?
  privateData     String?        // Hidden info revealed only when application is APPROVED
  autoApprove     Boolean        @default(false)
  
  // Requirements
  reqCountry      String?
  reqPhoneType    String?
  reqAgeMin       Int?
  reqAgeMax       Int?
  reqExperience   String?
  
  price           Float?
  recordingDuration Float?  // Duration in minutes (e.g. 2.5 for 2.5 hours = 150 min)
  status          String  @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  skills          ProjectSkill[]
  applications    Application[]
  comments        Comment[]
  languages       ProjectLanguage[]
  images          ProjectImage[]
  sentences       ProjectSentence[]
}

model ProjectSentence {
  id          String          @id @default(cuid())
  projectId   String
  text        String
  order       Int
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordings  VoiceRecording[]
  createdAt   DateTime        @default(now())
}

model VoiceRecording {
  id           String          @id @default(cuid())
  sentenceId   String
  userId       String
  fileUrl      String          // Cloudinary URL
  publicId     String          // Cloudinary public_id for deletion
  expiresAt    DateTime        // uploadedAt + 24h
  movedToCloud Boolean         @default(false)
  sentence     ProjectSentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id])
  createdAt    DateTime        @default(now())
  @@unique([sentenceId, userId])
}

model ProjectLanguage {
  id              String   @id @default(cuid())
  projectId       String
  language        String
  dialect         String?
  proficiency     String?
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectImage {
  id              String   @id @default(cuid())
  projectId       String
  url             String
  caption         String?
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectSkill {
  projectId String
  skillId   String
  project   Project @relation(fields: [projectId], references: [id])
  skill     Skill   @relation(fields: [skillId], references: [id])

  @@id([projectId, skillId])
}

model Application {
  id          String            @id @default(cuid())
  projectId   String
  userId      String
  status      String            @default("PENDING") // PENDING, ACCEPTED, WORKING, UNDER_REVIEW, APPROVED, PAID, REJECTED
  proofUrl    String?           // For task completion proof
  
  project     Project           @relation(fields: [projectId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([projectId, userId])
}

model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  fileUrl     String?
  imageUrl    String?
  
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Comment {
  id          String   @id @default(cuid())
  projectId   String
  authorId    String
  content     String
  parentId    String?
  
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String
  isRead      Boolean  @default(false)
  
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  isRead      Boolean  @default(false)
  link        String?
  
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model LearningResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String
  imageUrl    String?
  category    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
